@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to EventEase 🎉</h1>
    <p class="lead">Manage your events, venues, and bookings with ease.</p>

    <div class="mt-4">
        <a class="btn btn-primary m-2" asp-controller="Event" asp-action="Index">📅 Create Events</a>
        <a class="btn btn-success m-2" asp-controller="Venue" asp-action="Index">🏛 Create Venues</a>
        <a class="btn btn-warning m-2" asp-controller="Booking" asp-action="Index">📋 Create Bookings</a>
    </div>
</div>
