@model IEnumerable<EventEase.Models.BookingDetailsViewModel>

@{
    ViewData["Title"] = "Booking Details";
}

<h2 class="mb-3">Booking Details</h2>

<form asp-action="DetailsView" method="get" class="mb-4">
    <input type="text" name="search" class="form-control" placeholder="Search by Event Type, Event, Venue or Date" value="@Context.Request.Query["search"]" />
    <button type="submit" class="btn btn-primary mt-2">Search</button>
</form>

@if (!Model.Any())
{
    <p>No bookings found.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Event Type</th>
                <th>Booking ID</th>
                <th>Booking Date</th>
                <th>Event Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Venue Name</th>
                <th>Location</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventTypeName</td>
                    <td>@item.BookingId</td>
                    <td>@item.BookingDate.ToShortDateString()</td>
                    <td>@item.EventName</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>@item.VenueName</td>
                    <td>@item.Location</td>
                </tr>
            }
        </tbody>
    </table>
}
